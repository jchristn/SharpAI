{
  "CreatedUtc": "2026-04-11T00:00:00.000000Z",
  "SoftwareVersion": "4.0.0",
  "Logging": {
    "Servers": [
      {
        "Hostname": "127.0.0.1",
        "Port": 514,
        "RandomizePorts": false,
        "MinimumPort": 65000,
        "MaximumPort": 65535
      }
    ],
    "LogDirectory": "./logs/",
    "LogFilename": "./sharpai.log",
    "ConsoleLogging": true,
    "EnableColors": false,
    "MinimumSeverity": 0
  },
  "Storage": {
    "TempDirectory": "./temp/",
    "ModelsDirectory": "./models/"
  },
  "Database": {
    "Filename": "./sharpai.db",
    "Type": "Sqlite",
    "Port": 0,
    "RequireEncryption": false,
    "Debug": {
      "EnableForQueries": false,
      "EnableForResults": false
    }
  },
  "HuggingFace": {
    "ApiKey": "My HuggingFace API Key"
  },
  "Rest": {
    "Hostname": "*",
    "Port": 8000,
    "Protocols": {
      "EnableHttp1": true,
      "EnableHttp2": false,
      "EnableHttp3": false,
      "EnableHttp2Cleartext": false,
      "MaxConcurrentStreams": 100,
      "IdleTimeoutMs": 120000,
      "Http2": {
        "HeaderTableSize": 4096,
        "EnablePush": false,
        "MaxConcurrentStreams": 100,
        "InitialWindowSize": 65535,
        "MaxFrameSize": 16384,
        "MaxHeaderListSize": 65536
      },
      "Http3": {
        "MaxFieldSectionSize": 0,
        "QpackMaxTableCapacity": 0,
        "QpackBlockedStreams": 0,
        "EnableDatagram": false
      }
