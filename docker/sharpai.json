    "Timeout": {
      "DefaultTimeout": "00:00:00"
    },
    "WebSockets": {
      "Enable": false,
      "MaxMessageSize": 16777216,
      "ReceiveBufferSize": 65536,
      "CloseHandshakeTimeoutMs": 5000,
      "AllowClientSuppliedGuid": false,
      "ClientGuidHeaderName": "x-guid",
      "SupportedVersions": ["13"],
      "EnableHttp1": true,
      "EnableHttp2": false,
      "EnableHttp3": false
