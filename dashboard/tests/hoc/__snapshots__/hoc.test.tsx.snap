// Jest Snapshot v1, https://goo.gl/fbAQLP

exports[`withConnectivityValidation HOC should match snapshot for error state 1`] = `
<div
  data-testid="fallback"
  style="height: 100vh;"
>
  <div
    class="p"
    data-align="center"
    data-gap="8"
    data-justify="center"
    data-testid="error-flex"
    data-vertical="true"
  >
    <h1
      data-level="5"
      data-testid="error-title"
      data-weight="600"
    >
      Failed to validate connectivity. Please check your connection.
    </h1>
    <div
      data-testid="error-text"
    >
      "Network error"
    </div>
    <button
      data-testid="retry-button"
      type="primary"
    >
      Retry
    </button>
  </div>
</div>
`;

exports[`withConnectivityValidation HOC should match snapshot for loading state 1`] = `
<div
  data-testid="page-container"
  style="height: 100vh;"
>
  <div
    data-testid="page-loading"
  >
    Validating connectivity...
  </div>
</div>
`;

exports[`withConnectivityValidation HOC should match snapshot for success state 1`] = `
<div
  data-testid="test-component"
>
  Test Component with prop: 
  test
</div>
`;
