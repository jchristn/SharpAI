        class="landingLogo fade-in ant-flex css-dev-only-do-not-override-1vjf2v5 ant-flex-align-center"
        style="gap: 8px;"
      >
        <img
          alt="Sharp AI"
          height="50"
          src="/images/sharp-logo.png"
        />
        <span
          class="ant-typography css-dev-only-do-not-override-1vjf2v5"
          style="font-weight: 600; font-size: 27.77777777777778px;"
        >
          SharpAI
        </span>
      </div>
      <div
        class="ant-divider css-dev-only-do-not-override-1vjf2v5 ant-divider-horizontal"
        role="separator"
      />
      <form
        class="ant-form ant-form-vertical ant-form-hide-required-mark css-dev-only-do-not-override-1vjf2v5"
      >
        <div
          class="ant-flex css-dev-only-do-not-override-1vjf2v5 ant-flex-align-center"
        >
          <div
            class="ant-form-item css-dev-only-do-not-override-1vjf2v5"
            style="width: 400px;"
          >
            <div
              class="ant-row ant-form-item-row css-dev-only-do-not-override-1vjf2v5"
            >
              <div
                class="ant-col ant-form-item-label css-dev-only-do-not-override-1vjf2v5"
              >
                <label
                  class="ant-form-item-required ant-form-item-required-mark-hidden"
                  for="sharpAPIUrl"
                  title="SharpAI Server URL"
                >
                  SharpAI Server URL
                </label>
              </div>
              <div
                class="ant-col ant-form-item-control css-dev-only-do-not-override-1vjf2v5"
              >
                <div
                  class="ant-form-item-control-input"
                >
                  <div
                    class="ant-form-item-control-input-content"
                  >
                    <span
                      class="ant-input-group-wrapper ant-input-group-wrapper-lg ant-input-group-wrapper-outlined css-dev-only-do-not-override-1vjf2v5 ant-input-search ant-input-search-large ant-input-search-with-button"
                    >
                      <span
                        class="ant-input-wrapper ant-input-group css-dev-only-do-not-override-1vjf2v5"
                      >
                        <input
                          aria-required="true"
                          class="ant-input ant-input-lg css-dev-only-do-not-override-1vjf2v5 ant-input-outlined"
                          id="sharpAPIUrl"
                          type="search"
                          value="http://localhost:8000"
                        />
                        <span
                          class="ant-input-group-addon"
                        >
                          <button
                            class="ant-btn css-dev-only-do-not-override-1vjf2v5 ant-btn-default ant-btn-color-primary ant-btn-variant-solid ant-btn-lg ant-input-search-button"
